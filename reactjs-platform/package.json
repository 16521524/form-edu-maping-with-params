{
  "name": "reactjs-platform",
  "version": "0.1.0",
  "description": "Shared UI and platform utilities for Next.js apps",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "import": "./dist/ui.js",
      "default": "./dist/ui.js"
    },
    "./ui/*": {
      "types": "./dist/ui/*.d.ts",
      "import": "./dist/ui/*.js",
      "default": "./dist/ui/*.js"
    },
    "./utilities": {
      "types": "./dist/utilities/index.d.ts",
      "import": "./dist/utilities.js",
      "default": "./dist/utilities.js"
    },
    "./utilities/*": {
      "types": "./dist/utilities/*.d.ts",
      "import": "./dist/utilities/*.js",
      "default": "./dist/utilities/*.js"
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "ui": [
        "dist/ui/index.d.ts"
      ],
      "ui/*": [
        "dist/ui/*.d.ts"
      ],
      "utilities": [
        "dist/utilities/index.d.ts"
      ],
      "utilities/*": [
        "dist/utilities/*.d.ts"
      ],
      "*": [
        "dist/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "yarn clean && tsup && tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "prepack": "yarn build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pack:local": "yarn pack"
  },
  "peerDependencies": {
    "next": ">=15 <17",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.67.0"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "1.2.2",
    "@radix-ui/react-alert-dialog": "1.1.4",
    "@radix-ui/react-aspect-ratio": "1.1.1",
    "@radix-ui/react-avatar": "1.1.2",
    "@radix-ui/react-checkbox": "1.1.3",
    "@radix-ui/react-collapsible": "1.1.2",
    "@radix-ui/react-context-menu": "2.2.4",
    "@radix-ui/react-dialog": "1.1.4",
    "@radix-ui/react-dropdown-menu": "2.1.4",
    "@radix-ui/react-hover-card": "1.1.4",
    "@radix-ui/react-label": "2.1.1",
    "@radix-ui/react-menubar": "1.1.4",
    "@radix-ui/react-navigation-menu": "1.2.3",
    "@radix-ui/react-popover": "1.1.4",
    "@radix-ui/react-progress": "1.1.1",
    "@radix-ui/react-radio-group": "1.2.2",
    "@radix-ui/react-scroll-area": "1.2.2",
    "@radix-ui/react-select": "2.1.4",
    "@radix-ui/react-separator": "1.1.1",
    "@radix-ui/react-slider": "1.2.2",
    "@radix-ui/react-slot": "1.1.1",
    "@radix-ui/react-switch": "1.1.2",
    "@radix-ui/react-tabs": "1.1.2",
    "@radix-ui/react-toast": "1.2.4",
    "@radix-ui/react-toggle": "1.1.1",
    "@radix-ui/react-toggle-group": "1.1.1",
    "@radix-ui/react-tooltip": "1.1.6",
    "axios": "^1.13.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.0.4",
    "cookies-next": "^4.3.0",
    "date-fns": "4.1.0",
    "dayjs": "^1.11.18",
    "embla-carousel-react": "8.5.1",
    "input-otp": "1.4.1",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^0.454.0",
    "react-day-picker": "9.8.0",
    "react-resizable-panels": "^2.1.7",
    "react-toastify": "^11.0.5",
    "recharts": "2.15.4",
    "secure-ls": "^2.0.0",
    "sonner": "^1.7.4",
    "tailwind-merge": "^2.5.5",
    "vaul": "^1.1.2",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tsup": "^8.5.1",
    "tsup-plugin-prepend-directive": "^0.1.2",
    "typescript": "^5"
  }
}
