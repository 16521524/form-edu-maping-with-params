{
  "name": "my-v0-project",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "reactjs-platform"
  ],
  "scripts": {
    "build": "yarn build:platform && next build",
    "build:platform": "yarn --cwd reactjs-platform build",
    "dev": "yarn build:platform && next dev",
    "lint": "eslint .",
    "pack:platform": "yarn --cwd reactjs-platform pack:local",
    "start": "next start",
    "typecheck": "yarn build:platform && tsc -p tsconfig.json --noEmit",
    "typecheck:platform": "yarn --cwd reactjs-platform typecheck"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@tanstack/react-table": "^8.21.3",
    "autoprefixer": "^10.4.20",
    "clsx": "^2.1.1",
    "date-fns": "4.1.0",
    "lucide-react": "^0.454.0",
    "next": "16.0.7",
    "next-themes": "^0.4.6",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.67.0",
    "reactjs-platform": "0.1.0",
    "tailwind-merge": "^2.5.5",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.9",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "postcss": "^8.5",
    "tailwindcss": "^4.1.9",
    "tw-animate-css": "1.3.3",
    "typescript": "^5"
  }
}
